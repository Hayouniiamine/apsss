# Environment Variables

# App
NEXT_PUBLIC_APP_NAME="Ecole Privee Avicenne"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API (for future backend integration)
API_URL=http://localhost:8000

# Authentication (for production)
JWT_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# Database (for future integration)
DATABASE_URL="postgresql://user:password@localhost:5432/ecole_avicenne"

# File Storage (for future file uploads)
UPLOAD_DIR=/uploads
MAX_FILE_SIZE=5242880

# Notifications (for future implementation)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
WHATSAPP_API_KEY=
